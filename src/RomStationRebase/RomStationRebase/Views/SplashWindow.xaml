<Window x:Class="RomStationRebase.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RomStationRebase.ViewModels"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Width="520" Height="480"
        WindowStartupLocation="CenterScreen"
        Icon="/Resources/Images/rsr-logo.png">

    <Window.Resources>
        <!-- Barre de progression simple sans animation indéterminée -->
        <Style x:Key="SplashProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="#E0E0E0" Height="4"/>
                            <Border x:Name="PART_Track" Background="#E0E0E0" Height="4"/>
                            <Grid x:Name="PART_Indicator" ClipToBounds="True" HorizontalAlignment="Left">
                                <Border Background="{StaticResource AccentBrush}" Height="4"/>
                            </Grid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Padding externe pour que l'ombre portée soit visible -->
    <Border Padding="12" MouseLeftButtonDown="Window_MouseLeftButtonDown" Cursor="SizeAll">
        <Border CornerRadius="12"
                Background="{StaticResource SurfaceBrush}"
                ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.18"
                                  BlurRadius="24" ShadowDepth="4"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="140"/>  <!-- Zone logo -->
                    <RowDefinition Height="*"/>    <!-- Étapes -->
                    <RowDefinition Height="4"/>    <!-- ProgressBar -->
                    <RowDefinition Height="32"/>   <!-- Footer -->
                </Grid.RowDefinitions>

                <!-- ── Zone logo (fond AccentBrush) ── -->
                <Border Grid.Row="0" Background="{StaticResource AccentBrush}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Image Source="pack://application:,,,/Resources/Images/rsr-logo.png"
                               Width="64" Height="64"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="RomStation "
                                       FontSize="18" FontWeight="Normal"
                                       Foreground="White"/>
                            <TextBlock Text="Rebase"
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="White"/>
                        </StackPanel>
                        <TextBlock Text="{Binding AppVersion}"
                                   FontSize="11"
                                   Foreground="White" Opacity="0.7"
                                   HorizontalAlignment="Center"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ── Étapes ── -->
                <ScrollViewer x:Name="StepsScrollViewer"
                              Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Padding="24,16,24,8">
                    <ScrollViewer.Resources>
                        <!-- Scrollbar fine héritée de GlobalStyles -->
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource SidebarScrollBar}"/>
                    </ScrollViewer.Resources>
                    <ItemsControl ItemsSource="{Binding Steps}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:SplashStep}">
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Icône de statut 16×16 -->
                                    <Grid Grid.Column="0" Width="16" Height="16"
                                          VerticalAlignment="Center">

                                        <!-- Pending : anneau gris -->
                                        <Ellipse x:Name="PendingIcon"
                                                 Width="14" Height="14"
                                                 Stroke="#CCCCCC" StrokeThickness="1.5"
                                                 Fill="Transparent"/>

                                        <!-- Running : anneau accent en pointillés + rotation -->
                                        <Ellipse x:Name="RunningIcon"
                                                 Width="14" Height="14"
                                                 Stroke="{StaticResource AccentBrush}"
                                                 StrokeThickness="2"
                                                 StrokeDashArray="3 3"
                                                 Fill="Transparent"
                                                 Visibility="Collapsed"
                                                 RenderTransformOrigin="0.5,0.5">
                                            <Ellipse.RenderTransform>
                                                <RotateTransform/>
                                            </Ellipse.RenderTransform>
                                        </Ellipse>

                                        <!-- Success : cercle vert -->
                                        <Ellipse x:Name="SuccessBg"
                                                 Width="14" Height="14"
                                                 Fill="#2EB67D"
                                                 Visibility="Collapsed"/>
                                        <Path x:Name="SuccessCheck"
                                              Data="M 3,7 L 5.5,9.5 L 11,4"
                                              Stroke="White" StrokeThickness="1.5"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Visibility="Collapsed"/>

                                        <!-- Warning : cercle orange -->
                                        <Ellipse x:Name="WarningBg"
                                                 Width="14" Height="14"
                                                 Fill="#F5A623"
                                                 Visibility="Collapsed"/>
                                        <Path x:Name="WarningPath"
                                              Data="M 7,3.5 L 7,8 M 7,10 L 7,10.5"
                                              Stroke="White" StrokeThickness="1.5"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Visibility="Collapsed"/>

                                        <!-- Error : cercle rouge -->
                                        <Ellipse x:Name="ErrorBg"
                                                 Width="14" Height="14"
                                                 Fill="#E24B4A"
                                                 Visibility="Collapsed"/>
                                        <Path x:Name="ErrorPath"
                                              Data="M 4.5,4.5 L 9.5,9.5 M 9.5,4.5 L 4.5,9.5"
                                              Stroke="White" StrokeThickness="1.5"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Visibility="Collapsed"/>
                                    </Grid>

                                    <!-- Label + détail -->
                                    <StackPanel Grid.Column="1"
                                                Margin="10,0,0,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Label}"
                                                   FontSize="13"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <!-- Détail de l'étape — visible uniquement si Detail est non null -->
                                        <TextBlock Text="{Binding Detail}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,1,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Detail}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>

                                <DataTemplate.Triggers>

                                    <!-- Running : affiche l'anneau tournant + animation -->
                                    <DataTrigger Binding="{Binding Status}"
                                                 Value="{x:Static vm:SplashStepStatus.Running}">
                                        <Setter TargetName="PendingIcon"  Property="Visibility" Value="Collapsed"/>
                                        <Setter TargetName="RunningIcon"  Property="Visibility" Value="Visible"/>
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="SpinSB">
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="RunningIcon"
                                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                        From="0" To="360" Duration="0:0:1"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="SpinSB"/>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>

                                    <!-- Success -->
                                    <DataTrigger Binding="{Binding Status}"
                                                 Value="{x:Static vm:SplashStepStatus.Success}">
                                        <Setter TargetName="PendingIcon"   Property="Visibility" Value="Collapsed"/>
                                        <Setter TargetName="SuccessBg"     Property="Visibility" Value="Visible"/>
                                        <Setter TargetName="SuccessCheck"  Property="Visibility" Value="Visible"/>
                                    </DataTrigger>

                                    <!-- Warning -->
                                    <DataTrigger Binding="{Binding Status}"
                                                 Value="{x:Static vm:SplashStepStatus.Warning}">
                                        <Setter TargetName="PendingIcon"  Property="Visibility" Value="Collapsed"/>
                                        <Setter TargetName="WarningBg"    Property="Visibility" Value="Visible"/>
                                        <Setter TargetName="WarningPath"  Property="Visibility" Value="Visible"/>
                                    </DataTrigger>

                                    <!-- Error -->
                                    <DataTrigger Binding="{Binding Status}"
                                                 Value="{x:Static vm:SplashStepStatus.Error}">
                                        <Setter TargetName="PendingIcon" Property="Visibility" Value="Collapsed"/>
                                        <Setter TargetName="ErrorBg"     Property="Visibility" Value="Visible"/>
                                        <Setter TargetName="ErrorPath"   Property="Visibility" Value="Visible"/>
                                    </DataTrigger>

                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- ── Barre de progression ── -->
                <ProgressBar Grid.Row="2"
                             Value="{Binding SplashProgress, Mode=OneWay}"
                             Minimum="0" Maximum="100"
                             Style="{StaticResource SplashProgressBar}"/>

                <!-- ── Footer ── -->
                <Grid Grid.Row="3" Margin="16,0">
                    <TextBlock Text="{Binding SplashStatusText}"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>

                    <!-- Bouton Quit — visible uniquement en cas d'erreur -->
                    <Button HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Command="{Binding QuitCommand}"
                            Padding="14,5">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Content"    Value="Quit"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasError}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

            </Grid>
        </Border>
    </Border>
</Window>

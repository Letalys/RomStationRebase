<Window x:Class="RomStationRebase.Views.Dialogs.RebaseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:res="clr-namespace:RomStationRebase.Resources"
        xmlns:vm="clr-namespace:RomStationRebase.ViewModels"
        xmlns:helpers="clr-namespace:RomStationRebase.Helpers"
        xmlns:models="clr-namespace:RomStationRebase.Models"
        mc:Ignorable="d"
        Title="{x:Static res:Strings.Rebase_Title}"
        Icon="/Resources/Images/rsr-logo.png"
        Height="640" Width="880"
        MinHeight="560" MinWidth="720"
        WindowStyle="None" AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource BackgroundBrush}"
        d:DataContext="{d:DesignInstance Type=vm:RebaseViewModel, IsDesignTimeCreatable=False}">

    <Window.Resources>
        <BooleanToVisibilityConverter            x:Key="BoolToVisibilityConverter"/>
        <helpers:StringToImageSourceConverter    x:Key="StringToImageSourceConverter"/>

        <Style x:Key="ChromeButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width"           Value="46"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="12"/>
        </Style>
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource ChromeButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource CloseButtonHoverBrush}"/>
                    <Setter Property="Opacity"    Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid épuré -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"               Value="{DynamicResource DataGridBackgroundBrush}"/>
            <Setter Property="BorderBrush"              Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="RowBackground"            Value="{DynamicResource DataGridBackgroundBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource DataGridAlternatingRowBrush}"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource DataGridGridLinesBrush}"/>
            <Setter Property="VerticalGridLinesBrush"   Value="Transparent"/>
            <Setter Property="FontSize"                 Value="12"/>
            <Setter Property="SelectionMode"            Value="Single"/>
            <Setter Property="SelectionUnit"            Value="FullRow"/>
            <Setter Property="RowHeight"                Value="44"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="{DynamicResource DataGridColumnHeaderBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="8,5"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DataGridCellSelectedBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style cellule pour la colonne jaquette — padding réduit -->
        <Style x:Key="CoverCellStyle" TargetType="DataGridCell"
               BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Setter Property="Padding" Value="4,2"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>

        <!-- Coloration des lignes du DataGrid selon le statut du jeu -->
        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:RebaseItemStatus.Copying}">
                    <Setter Property="Background" Value="{DynamicResource AccentLightBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:RebaseItemStatus.Failed}">
                    <Setter Property="Background" Value="{DynamicResource DataGridRowFailedBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:RebaseItemStatus.Skipped}">
                    <Setter Property="Background" Value="{DynamicResource DataGridRowSkippedBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>   <!-- Titlebar -->
            <RowDefinition Height="Auto"/> <!-- Configuration -->
            <RowDefinition Height="1"/>    <!-- Séparateur -->
            <RowDefinition Height="Auto"/> <!-- Progression + stats -->
            <RowDefinition Height="1"/>    <!-- Séparateur -->
            <RowDefinition Height="*"/>    <!-- DataGrid -->
            <RowDefinition Height="48"/>   <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ── Titlebar ── -->
        <Border Grid.Row="0" Background="{DynamicResource AccentBrush}"
                MouseLeftButtonDown="Titlebar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{x:Static res:Strings.Rebase_Title}"
                           Foreground="White" FontWeight="SemiBold" FontSize="13"
                           VerticalAlignment="Center" Margin="14,0"/>
                <Button Grid.Column="1" x:Name="MaximizeButton"
                        Style="{StaticResource ChromeButton}"
                        Content="□" Click="MaximizeButton_Click"/>
                <Button Grid.Column="2"
                        Style="{StaticResource CloseButton}"
                        Content="✕" Click="CloseButton_Click"/>
            </Grid>
        </Border>

        <!-- ── Zone de configuration ── -->
        <Grid Grid.Row="1" Margin="16,12,16,12" IsEnabled="{Binding IsNotRunning}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Destination -->
            <StackPanel Grid.Column="0">
                <TextBlock Style="{StaticResource SectionLabel}"
                           Text="{x:Static res:Strings.Rebase_TargetPath}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding TargetPath, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"/>
                    <Button Grid.Column="2" Content="{x:Static res:Strings.Rebase_Browse}"
                            Command="{Binding BrowseCommand}" Padding="10,6"/>
                </Grid>
            </StackPanel>

            <!-- Architecture -->
            <StackPanel Grid.Column="2" MinWidth="180">
                <TextBlock Style="{StaticResource SectionLabel}"
                           Text="{x:Static res:Strings.Rebase_Architecture}"/>
                <ComboBox ItemsSource="{Binding Architectures}"
                          SelectedItem="{Binding SelectedArchitecture}"
                          DisplayMemberPath="Label"
                          Padding="8,6" Height="30"/>
            </StackPanel>

            <!-- Options : M3U + Doublons + Copies concurrentes -->
            <StackPanel Grid.Column="4" MinWidth="260" VerticalAlignment="Top">

                <!-- Ligne 1 : ToggleButton M3U + politique doublons -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <ToggleButton IsChecked="{Binding GenerateM3U}"
                                      Style="{StaticResource ToggleSwitchButton}"/>
                        <TextBlock Text="M3U" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2"
                               Text="{x:Static res:Strings.Rebase_DuplicatePolicy}"
                               Style="{StaticResource SectionLabel}"
                               VerticalAlignment="Center" Margin="0"/>
                    <ComboBox Grid.Column="4"
                              SelectedIndex="{Binding DuplicatePolicyIndex}"
                              Padding="6,4" Height="28">
                        <ComboBoxItem Content="{x:Static res:Strings.Rebase_DuplicatePolicy_Ignore}"/>
                        <ComboBoxItem Content="{x:Static res:Strings.Rebase_DuplicatePolicy_Overwrite}"/>
                    </ComboBox>
                </Grid>

                <!-- Copies concurrentes + Tentatives + Délai entre tentatives : Grid aligné -->
                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>   <!-- Label -->
                        <ColumnDefinition Width="Auto"/>   <!-- Bouton − -->
                        <ColumnDefinition Width="Auto"/>   <!-- Valeur -->
                        <ColumnDefinition Width="Auto"/>   <!-- Bouton + -->
                        <ColumnDefinition Width="Auto"/>   <!-- Unité (optionnel, uniquement ligne Délai) -->
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Ligne 1 : Copies concurrentes -->
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="{x:Static res:Strings.Rebase_ParallelCopies}"
                               Style="{StaticResource SectionLabel}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Button Grid.Row="0" Grid.Column="1"
                            Content="−" Width="22" Height="22" Padding="0" FontSize="14"
                            Command="{Binding DecrementParallelCommand}"/>
                    <TextBlock Grid.Row="0" Grid.Column="2"
                               Text="{Binding MaxParallelCopies}"
                               Width="32" TextAlignment="Center"
                               VerticalAlignment="Center" FontSize="13" Margin="4,0"/>
                    <Button Grid.Row="0" Grid.Column="3"
                            Content="+" Width="22" Height="22" Padding="0" FontSize="14"
                            Command="{Binding IncrementParallelCommand}"/>

                    <!-- Ligne 2 : Tentatives -->
                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="{x:Static res:Strings.Rebase_RetryAttempts}"
                               Style="{StaticResource SectionLabel}"
                               VerticalAlignment="Center" Margin="0,6,8,0"/>
                    <Button Grid.Row="1" Grid.Column="1"
                            Content="−" Width="22" Height="22" Padding="0" FontSize="14" Margin="0,6,0,0"
                            Command="{Binding DecrementRetryCommand}"/>
                    <TextBlock Grid.Row="1" Grid.Column="2"
                               Text="{Binding RetryCount}"
                               Width="32" TextAlignment="Center"
                               VerticalAlignment="Center" FontSize="13" Margin="4,6,4,0"/>
                    <Button Grid.Row="1" Grid.Column="3"
                            Content="+" Width="22" Height="22" Padding="0" FontSize="14" Margin="0,6,0,0"
                            Command="{Binding IncrementRetryCommand}"/>

                    <!-- Ligne 3 : Délai entre tentatives (avec suffixe "sec.") -->
                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="{x:Static res:Strings.Rebase_RetryDelay}"
                               Style="{StaticResource SectionLabel}"
                               VerticalAlignment="Center" Margin="0,6,8,0"/>
                    <Button Grid.Row="2" Grid.Column="1"
                            Content="−" Width="22" Height="22" Padding="0" FontSize="14" Margin="0,6,0,0"
                            Command="{Binding DecrementRetryDelayCommand}"/>
                    <TextBlock Grid.Row="2" Grid.Column="2"
                               Text="{Binding RetryDelay}"
                               Width="32" TextAlignment="Center"
                               VerticalAlignment="Center" FontSize="13" Margin="4,6,4,0"/>
                    <Button Grid.Row="2" Grid.Column="3"
                            Content="+" Width="22" Height="22" Padding="0" FontSize="14" Margin="0,6,0,0"
                            Command="{Binding IncrementRetryDelayCommand}"/>
                    <TextBlock Grid.Row="2" Grid.Column="4"
                               Text="{x:Static res:Strings.Rebase_RetryDelayUnit}"
                               VerticalAlignment="Center" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="6,6,0,0"/>
                </Grid>
            </StackPanel>
        </Grid>

        <!-- Séparateur -->
        <Rectangle Grid.Row="2" Fill="{DynamicResource BorderBrush}"/>

        <!-- ── Barre de progression + stats ── -->
        <Grid Grid.Row="3" Margin="16,10,16,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="6"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <!-- Value piloté exclusivement par BeginAnimation — pas de binding ni de Style pour éviter tout conflit -->
            <ProgressBar x:Name="RebaseProgressBar" Grid.Row="0"
                         Minimum="0" Maximum="100" Height="6"
                         Foreground="{DynamicResource ProgressBarFillBrush}" Background="{DynamicResource ProgressBarTrackBrush}" BorderThickness="0"/>
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                           FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Grid.Column="1" Text="{Binding SpeedText}"
                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="16,0,16,0"/>
                <TextBlock Grid.Column="2" Text="{Binding EtaText}"
                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Grid.Column="3" Text="{Binding EstimatedSizeText}"
                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="16,0,0,0"/>
            </Grid>
        </Grid>

        <!-- Séparateur -->
        <Rectangle Grid.Row="4" Fill="{DynamicResource BorderBrush}"/>

        <!-- ── DataGrid jeux ── -->
        <DataGrid Grid.Row="5"
                  ItemsSource="{Binding RebaseItems}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  CanUserSortColumns="True"
                  CanUserResizeRows="False"
                  Margin="0">
            <DataGrid.Columns>

                <!-- Jaquette 36×36 -->
                <DataGridTemplateColumn Width="48" CanUserSort="False" CanUserResize="False"
                                        CellStyle="{StaticResource CoverCellStyle}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Width="36" Height="36" Background="{DynamicResource DataGridCoverPlaceholderBrush}" CornerRadius="2">
                                <Image Source="{Binding CoverPath, Converter={StaticResource StringToImageSourceConverter}}"
                                       Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Icône statut -->
                <DataGridTextColumn Width="30" Binding="{Binding StatusIcon}" CanUserSort="False">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="FontSize"            Value="13"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Titre -->
                <DataGridTextColumn Header="{x:Static res:Strings.Rebase_Column_Title}"
                                    Width="*" Binding="{Binding Title}"/>

                <!-- Système avec logo 14×14 -->
                <DataGridTemplateColumn Header="{x:Static res:Strings.Rebase_Column_System}"
                                        Width="150" SortMemberPath="SystemName">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Image Source="{Binding SystemImagePath, Converter={StaticResource StringToImageSourceConverter}}"
                                       Width="14" Height="14" Margin="0,0,5,0" VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text="{Binding SystemName}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Fichiers — aligné à droite (convention UI pour les nombres, facilite la comparaison visuelle) -->
                <DataGridTextColumn Header="{x:Static res:Strings.Rebase_Column_Files}"
                                    Width="80" Binding="{Binding FileCount}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Margin" Value="0,0,12,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                            <Setter Property="HorizontalContentAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="0,0,12,0"/>
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                </DataGridTextColumn>

                <!-- Statut texte -->
                <DataGridTextColumn Header="{x:Static res:Strings.Rebase_Column_Status}"
                                    Width="110" Binding="{Binding StatusText}"/>

                <!-- Erreur -->
                <DataGridTextColumn Header="{x:Static res:Strings.Rebase_Column_Error}"
                                    Width="180" Binding="{Binding ErrorDetail}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            <Setter Property="Foreground"   Value="{DynamicResource ErrorTextBrush}"/>
                            <Setter Property="ToolTip"      Value="{Binding ErrorDetail}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- ── Footer ── -->
        <Border Grid.Row="6" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="{x:Static res:Strings.Rebase_OpenFolder}"
                            Command="{Binding OpenFolderCommand}"
                            Padding="10,6" Margin="0,0,8,0"/>
                    <Button Content="{x:Static res:Strings.Rebase_ExportLog}"
                            Command="{Binding ExportLogCommand}"
                            Padding="10,6"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="{Binding PauseResumeText}"
                            Command="{Binding PauseResumeCommand}"
                            Padding="10,6" Margin="0,0,8,0"
                            Visibility="{Binding ShowPauseResume, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <Button Content="{x:Static res:Strings.Rebase_Cancel}"
                            Command="{Binding CancelCommand}"
                            Padding="10,6" Margin="0,0,8,0"
                            Visibility="{Binding ShowPauseResume, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <Button Content="{x:Static res:Strings.Rebase_Cancelling}"
                            IsEnabled="False"
                            Padding="10,6" Margin="0,0,8,0"
                            Visibility="{Binding IsCancelling, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <Button Content="{x:Static res:Strings.Rebase_CancelCalcTitle}"
                            Command="{Binding CancelCalculationCommand}"
                            Padding="10,6" Margin="0,0,8,0"
                            Visibility="{Binding IsSizeCalculating, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <Button Content="{x:Static res:Strings.Rebase_Start}"
                            Command="{Binding StartRebaseCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Padding="14,6"
                            Visibility="{Binding CanShowStart, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

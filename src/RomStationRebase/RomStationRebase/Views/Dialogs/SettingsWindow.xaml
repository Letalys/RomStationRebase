<Window x:Class="RomStationRebase.Views.Dialogs.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:res="clr-namespace:RomStationRebase.Resources"
        xmlns:vm="clr-namespace:RomStationRebase.ViewModels"
        mc:Ignorable="d"
        Title="{x:Static res:Strings.Settings_Title}"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Width="520" Height="680"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel, IsDesignTimeCreatable=False}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <Border Padding="12">
        <!-- Ombre portée douce, comme ConfirmDialog -->
        <Border CornerRadius="12" Background="{DynamicResource SurfaceBrush}">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.18" BlurRadius="20" ShadowDepth="4"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="48"/>    <!-- Titlebar -->
                    <RowDefinition Height="*"/>     <!-- Corps avec scroll -->
                    <RowDefinition Height="Auto"/>  <!-- Footer -->
                </Grid.RowDefinitions>

                <!-- ── Titlebar : fond violet, draggable, bouton Close ── -->
                <Border Grid.Row="0"
                        Background="{DynamicResource AccentBrush}"
                        CornerRadius="12,12,0,0"
                        MouseLeftButtonDown="Titlebar_MouseLeftButtonDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{x:Static res:Strings.Settings_Title}"
                                   Foreground="White" FontWeight="SemiBold" FontSize="13"
                                   VerticalAlignment="Center" Margin="18,0"/>
                        <Button Grid.Column="1"
                                Width="36" Height="32"
                                Background="Transparent" BorderThickness="0"
                                Foreground="White" FontSize="12"
                                Content="✕"
                                Cursor="Hand"
                                Click="CloseButton_Click"/>
                    </Grid>
                </Border>

                <!-- ── Corps : grille 2 colonnes (label | contrôle) ── -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="28,20,28,12">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="140"/>  <!-- Colonne labels -->
                            <ColumnDefinition Width="*"/>                    <!-- Colonne ComboBox -->
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Header Général -->
                            <RowDefinition Height="Auto"/>  <!-- Ligne Langue -->
                            <RowDefinition Height="Auto"/>  <!-- Message restart -->
                            <RowDefinition Height="24"/>    <!-- Espacement inter-sections -->
                            <RowDefinition Height="Auto"/>  <!-- Header Affichage -->
                            <RowDefinition Height="Auto"/>  <!-- Ligne Thème -->
                            <RowDefinition Height="24"/>    <!-- Espacement avant EMPLACEMENTS -->
                            <RowDefinition Height="Auto"/>  <!-- Header EMPLACEMENTS -->
                            <RowDefinition Height="Auto"/>  <!-- Bouton dossier installation -->
                            <RowDefinition Height="Auto"/>  <!-- Bouton dossier données utilisateur -->
                            <RowDefinition Height="Auto"/>  <!-- Bouton dossier RomStation -->
                            <RowDefinition Height="24"/>    <!-- Espacement avant À PROPOS -->
                            <RowDefinition Height="Auto"/>  <!-- Header À PROPOS -->
                            <RowDefinition Height="Auto"/>  <!-- Version -->
                            <RowDefinition Height="Auto"/>  <!-- Copyright -->
                            <RowDefinition Height="Auto"/>  <!-- Bouton GitHub -->
                        </Grid.RowDefinitions>

                        <!-- Header Général (s'étend sur les 2 colonnes) -->
                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                                   Text="{x:Static res:Strings.Settings_Section_General}"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,12"/>

                        <!-- Ligne Langue : label à gauche, ComboBox à droite -->
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="{x:Static res:Strings.Settings_Language}"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,0"/>
                        <ComboBox Grid.Row="1" Grid.Column="1"
                                  SelectedValue="{Binding SelectedLanguage}"
                                  SelectedValuePath="Tag"
                                  HorizontalAlignment="Stretch">
                            <ComboBoxItem Tag="auto" Content="{x:Static res:Strings.Settings_Language_Auto}"/>
                            <ComboBoxItem Tag="fr"   Content="{x:Static res:Strings.Settings_Language_Fr}"/>
                            <ComboBoxItem Tag="en"   Content="{x:Static res:Strings.Settings_Language_En}"/>
                        </ComboBox>

                        <!-- Message de redémarrage — visible uniquement si la langue a changé (span 2 colonnes) -->
                        <TextBlock Grid.Row="2" Grid.ColumnSpan="2"
                                   Text="{x:Static res:Strings.Settings_RestartRequired}"
                                   FontSize="11"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Margin="0,8,0,0"
                                   Visibility="{Binding ShowRestartMessage, Converter={StaticResource BoolToVisibility}}"/>

                        <!-- Header Affichage (s'étend sur les 2 colonnes) -->
                        <TextBlock Grid.Row="4" Grid.ColumnSpan="2"
                                   Text="{x:Static res:Strings.Settings_Section_Display}"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,12"/>

                        <!-- Ligne Thème : label à gauche, ComboBox à droite -->
                        <TextBlock Grid.Row="5" Grid.Column="0"
                                   Text="{x:Static res:Strings.Settings_Theme}"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,0"/>
                        <ComboBox Grid.Row="5" Grid.Column="1"
                                  SelectedValue="{Binding SelectedTheme}"
                                  SelectedValuePath="Tag"
                                  HorizontalAlignment="Stretch">
                            <ComboBoxItem Tag="Light" Content="{x:Static res:Strings.Settings_Theme_Light}"/>
                        </ComboBox>

                        <!-- Header EMPLACEMENTS (span 2 colonnes) -->
                        <TextBlock Grid.Row="7" Grid.ColumnSpan="2"
                                   Text="{x:Static res:Strings.Settings_Section_Locations}"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,12"/>

                        <!-- Bouton Dossier d'installation (span 2 colonnes) -->
                        <Button Grid.Row="8" Grid.ColumnSpan="2"
                                Content="{x:Static res:Strings.Settings_OpenInstallFolder}"
                                Command="{Binding OpenInstallFolderCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Padding="12,8" Margin="0,0,0,6"/>

                        <!-- Bouton Dossier de données utilisateur (span 2 colonnes) -->
                        <Button Grid.Row="9" Grid.ColumnSpan="2"
                                Content="{x:Static res:Strings.Settings_OpenUserDataFolder}"
                                Command="{Binding OpenUserDataFolderCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Padding="12,8" Margin="0,0,0,6"/>

                        <!-- Bouton Dossier RomStation — désactivé si le chemin n'est pas disponible -->
                        <Button Grid.Row="10" Grid.ColumnSpan="2"
                                Content="{x:Static res:Strings.Settings_OpenRomStationFolder}"
                                Command="{Binding OpenRomStationFolderCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Padding="12,8"/>

                        <!-- Header À PROPOS (span 2 colonnes) -->
                        <TextBlock Grid.Row="12" Grid.ColumnSpan="2"
                                   Text="{x:Static res:Strings.Settings_Section_About}"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,12"/>

                        <!-- Version : "RomStation Rebase v1.0.0" -->
                        <TextBlock Grid.Row="13" Grid.ColumnSpan="2"
                                   Text="{Binding AppVersionText}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,0,0,4"/>

                        <!-- Copyright : "© Letalys — Licence MIT" -->
                        <TextBlock Grid.Row="14" Grid.ColumnSpan="2"
                                   Text="{Binding CopyrightText}"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,12"/>

                        <!-- Bouton : ouvrir le dépôt GitHub dans le navigateur -->
                        <Button Grid.Row="15" Grid.ColumnSpan="2"
                                Content="{x:Static res:Strings.Settings_About_OpenRepository}"
                                Command="{Binding OpenRepositoryCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Padding="12,8"/>

                    </Grid>

                </ScrollViewer>

                <!-- ── Footer : boutons Annuler + Enregistrer alignés à droite ── -->
                <Border Grid.Row="2"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="16,10">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="{x:Static res:Strings.Settings_Cancel}"
                                Padding="16,7" Margin="0,0,8,0"
                                Command="{Binding CancelCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <Button Content="{x:Static res:Strings.Settings_Save}"
                                Style="{StaticResource PrimaryButton}"
                                Padding="16,7"
                                Command="{Binding SaveCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Border>
</Window>

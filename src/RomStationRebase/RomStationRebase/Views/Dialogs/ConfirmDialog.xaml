<Window x:Class="RomStationRebase.Views.Dialogs.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Width="480"
        SizeToContent="Height"
        MinHeight="240"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">

    <Border Padding="12">
        <!-- Ombre portée douce -->
        <Border CornerRadius="12"
                Background="{StaticResource SurfaceBrush}">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.18"
                                  BlurRadius="20" ShadowDepth="4"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="56"/>   <!-- Header -->
                    <RowDefinition Height="*"/>    <!-- Corps -->
                    <RowDefinition Height="Auto"/> <!-- Footer -->
                </Grid.RowDefinitions>

                <!-- Header — fond AccentBrush, draggable -->
                <Border Grid.Row="0"
                        Background="{StaticResource AccentBrush}"
                        CornerRadius="12,12,0,0"
                        MouseLeftButtonDown="Header_MouseLeftButtonDown"
                        Cursor="SizeAll">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="20,0">
                        <!-- Icône info (cercle blanc + i) -->
                        <Grid Width="24" Height="24" Margin="0,0,12,0">
                            <Ellipse Fill="White" Opacity="0.25"/>
                            <TextBlock Text="i" FontSize="13" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock x:Name="TitleText"
                                   FontSize="15" FontWeight="Medium"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Corps — message -->
                <Border Grid.Row="1" Padding="24,20,24,8">
                    <TextBlock x:Name="MessageText"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               LineHeight="20"/>
                </Border>

                <!-- Footer — boutons alignés à droite -->
                <Border Grid.Row="2"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="16,10">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button x:Name="SecondaryButton"
                                Margin="0,0,8,0"
                                Padding="16,7"
                                Click="SecondaryButton_Click"/>
                        <Button x:Name="PrimaryButton"
                                Style="{StaticResource PrimaryButton}"
                                Padding="16,7"
                                Click="PrimaryButton_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Border>
</Window>
